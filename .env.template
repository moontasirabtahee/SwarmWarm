# ==============================================================================
# SWARMWARM GLOBAL INFRASTRUCTURE ENVIRONMENT TEMPLATE
# Copy this file to .env and configure local secret parameters.
# ==============================================================================

# ----- Web Server -----
PORT=8000
ENV=development   # development | staging | production

# ----- Database -----
# Dev default (leave unset) uses local SQLite: sqlite:///swarmwarm.db
# Production: point at PostgreSQL and run `alembic upgrade head`.
#   DATABASE_URL=postgresql+psycopg://swarmwarm:password@localhost:5432/swarmwarm
# DATABASE_URL=

# ----- Cryptographic Keys -----
# SWARMWARM_SECRET_KEY: AES-256-GCM master key for encrypting mailbox credentials.
#   Must resolve to 32 bytes. Generate with:
#     python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
SWARMWARM_SECRET_KEY=base64_encoded_32_byte_key_here
# SWARMWARM_JWT_SECRET: Secret used to sign HS256 JWT session tokens.
#   Generate with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SWARMWARM_JWT_SECRET=random_jwt_signing_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Access Control -----
# Comma-separated emails granted the admin role on signup.
ADMIN_EMAILS=ieee.dobby1998@gmail.com
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=300

# ----- CORS -----
# Comma-separated allowed origins. Use explicit origins in production, not "*".
CORS_ORIGINS=*

# ----- Redis Message Broker -----
REDIS_BROKER_URL=redis://localhost:6379/0

# ----- Local AI Microservice Tunnel -----
LOCAL_AI_TUNNEL_URL=https://your-cloudflare-tunnel.trycloudflare.com
LOCAL_AI_API_KEY=your_local_ai_authentication_bearer_token
LOCAL_AI_MODEL=gemma

# ----- Feature Flags -----
# When true, mailbox onboarding performs a real SMTP/IMAP login before saving.
VALIDATE_MAILBOX_CONNECTIONS=false

# ----- Transactional Email -----
EMAIL_BACKEND=console          # console (dev, prints links) | smtp
EMAIL_FROM=no-reply@swarmwarm.io
PUBLIC_BASE_URL=http://localhost:8000
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ----- Billing (Stripe) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# ----- Observability -----
SENTRY_DSN=
