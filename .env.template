# ==============================================================================
# SWARMWARM GLOBAL INFRASTRUCTURE ENVIRONMENT TEMPLATE
# Copy this file to .env and configure local secret parameters.
# ==============================================================================

# Web Server Parameters
PORT=8000
ENV=development # development, staging, production

# Cryptographic Keys
# SWARMWARM_SECRET_KEY: Used for signing JWT sessions (Base64 encoded string)
SWARMWARM_SECRET_KEY=base64_encoded_signing_key_placeholder_here_32_bytes
# SWARMWARM_DECRYPTION_KEY: Master hex key (32 bytes / 64 hex characters) for symmetric GCM encryption
SWARMWARM_DECRYPTION_KEY=hex_master_decryption_key_64_characters_here

# Supabase Database Configuration
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_jwt_token

# Redis Decoupled Message Broker
REDIS_BROKER_URL=redis://localhost:6379/0

# Local AI Microservice Tunnel Endpoint
LOCAL_AI_TUNNEL_URL=https://your-cloudflare-tunnel.trycloudflare.com
LOCAL_AI_API_KEY=your_local_ai_authentication_bearer_token
